{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "10771669122641600906"
    }
  },
  "parameters": {
    "storageLocation": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the storage account that holds the Hyroglyphis knowledge documents."
      }
    },
    "searchLocation": {
      "type": "string",
      "defaultValue": "eastus",
      "metadata": {
        "description": "Azure region for Azure AI Search. East US was required for capacity for the current live stack."
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique name for the storage account."
      }
    },
    "containerName": {
      "type": "string",
      "defaultValue": "knowledge",
      "metadata": {
        "description": "Blob container name used for knowledge documents."
      }
    },
    "searchServiceName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique name for the Azure AI Search service."
      }
    },
    "searchSkuName": {
      "type": "string",
      "defaultValue": "basic",
      "allowedValues": [
        "basic",
        "standard",
        "standard2",
        "standard3",
        "storage_optimized_l1",
        "storage_optimized_l2"
      ],
      "metadata": {
        "description": "Search SKU name."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Optional tag overrides."
      }
    }
  },
  "variables": {
    "defaultTags": {
      "app": "hyroglyphis",
      "environment": "prod",
      "purpose": "foundry-iq"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('storageLocation')]",
      "tags": "[union(variables('defaultTags'), parameters('tags'))]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "properties": {
        "accessTier": "Hot",
        "allowBlobPublicAccess": false,
        "allowCrossTenantReplication": false,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', parameters('storageAccountName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', parameters('storageAccountName'), 'default', parameters('containerName'))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2025-05-01",
      "name": "[parameters('searchServiceName')]",
      "location": "[parameters('searchLocation')]",
      "tags": "[union(variables('defaultTags'), parameters('tags'))]",
      "sku": {
        "name": "[parameters('searchSkuName')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "authOptions": {
          "aadOrApiKey": {
            "aadAuthFailureMode": "http401WithBearerChallenge"
          }
        },
        "disableLocalAuth": false,
        "hostingMode": "Default",
        "networkRuleSet": {
          "bypass": "None",
          "ipRules": []
        },
        "partitionCount": 1,
        "publicNetworkAccess": "Enabled",
        "replicaCount": 1,
        "semanticSearch": "free"
      }
    }
  ],
  "outputs": {
    "storageAccountId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[parameters('storageAccountName')]"
    },
    "storageBlobEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-05-01').primaryEndpoints.blob]"
    },
    "knowledgeContainerName": {
      "type": "string",
      "value": "[parameters('containerName')]"
    },
    "searchServiceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Search/searchServices', parameters('searchServiceName'))]"
    },
    "searchEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Search/searchServices', parameters('searchServiceName')), '2025-05-01').endpoint]"
    },
    "searchPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Search/searchServices', parameters('searchServiceName')), '2025-05-01', 'full').identity.principalId]"
    }
  }
}