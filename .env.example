# Optional Gemini / alt video hooks
API_KEY=
GEMINI_API_KEY=
FAL_KEY=

# Core OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_STORYBOARD_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_VIDEO_MODEL=sora-2

# Azure AI Foundry / Azure OpenAI
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_KEY=
AZURE_AI_FOUNDRY_MODEL=Phi-4
AZURE_AI_FOUNDRY_API_VERSION=
AZURE_AI_FOUNDRY_IMAGE_MODEL=gpt-image-2

AZURE_EXISTING_AIPROJECT_ENDPOINT=
AZURE_OPENAI_COMPLETIONS_KEY=
AZURE_OPENAI_COMPLETIONS_MODEL=

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_TEXT_MODEL=
AZURE_OPENAI_STORYBOARD_MODEL=
AZURE_OPENAI_POLISH_MODEL=
AZURE_OPENAI_VISION_MODEL=
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2
AZURE_OPENAI_VIDEO_DEPLOYMENT=

AZURE_VIDEO_ENDPOINT=
AZURE_VIDEO_KEY=
AZURE_VIDEO_MODEL=sora-2

# Optional IQ briefing configuration
HYROGLYPHIS_IQ_PROVIDER=auto
AZURE_FOUNDRY_IQ_AGENT_NAME=
AZURE_FOUNDRY_IQ_AGENT_VERSION=
AZURE_OPENAI_IQ_MODEL=gpt-4.1-mini

# ARV Thumbnail Studio
# Where generated style profiles, sessions and exported thumbnails are stored.
ARV_THUMBNAIL_DATA_DIR=data/thumbnail-studio
# Optional default folder of reference thumbnails analyzed on the server.
ARV_THUMBNAIL_DEFAULT_REFERENCE_DIR=

# Optional ARV live auth
ARV_OPERATOR_TOKEN=
