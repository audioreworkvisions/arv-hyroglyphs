{
  "name": "hyroglyphs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/audioreworkvisions/arv-hyroglyphs.git"
  },
  "homepage": "https://github.com/audioreworkvisions/arv-hyroglyphs",
  "bugs": {
    "url": "https://github.com/audioreworkvisions/arv-hyroglyphs/issues"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run typecheck && vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --target=node22 --packages=external --outfile=build/server/server.cjs",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "start": "node build/server/server.cjs"
  },
  "dependencies": {
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth": "^1.10.1",
    "@azure/identity": "^4.13.1",
    "@babylonjs/core": "^8.56.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "file-saver": "^2.0.5",
    "fluent-ffmpeg": "^2.1.3",
    "gifenc": "1.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.557.0",
    "openai": "^6.34.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/file-saver": "^2.0.7",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^8.0.16"
  }
}
